# ──────────────────────────────────────────────────────────
# EduSync Environment Variables
# ──────────────────────────────────────────────────────────

# Supabase (get from: https://supabase.com → Project Settings → API)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# NVIDIA AI (get from: https://build.nvidia.com → API Key)
VITE_NVIDIA_API_KEY=your_nvidia_api_key_here

# ── AI Model Selection ──────────────────────────────────────────────────────
# Model used in: Timetable Maker (subject extraction + timetable generation)
# Options (copy-paste any):
#   moonshotai/kimi-k2-instruct       ← Kimi K2 (current)
#   meta/llama-3.3-70b-instruct       ← Llama 3.3 70B
#   mistralai/mistral-large            ← Mistral Large
#   google/gemma-3-27b-it              ← Gemma 3 27B
VITE_TIMETABLE_MODEL=meta/llama-3.3-70b-instruct

# Model used in: Record Book PDF maker (experiment descriptions)
# Options same as above
VITE_RECORDBOOK_MODEL=meta/llama-3.3-70b-instruct
